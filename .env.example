# =============================================================================
# Ralph Loop - Autonomous Coding Agent
# =============================================================================
# Copy to .env and set your API key. That's it.

# --- API Key (required) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Model (optional, defaults to claude-sonnet-4-20250514) ---
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001
# RALPH_MODEL=claude-sonnet-4-20250514

# --- Provider (optional, defaults to claude-sdk) ---
# claude-sdk:    Uses Claude Code CLI (recommended, best quality)
# deep-agents:   Uses LangGraph (supports OpenAI/Gemini via langchain model strings)
# RALPH_PROVIDER=claude-sdk

# --- For Deep Agents with OpenAI ---
# OPENAI_API_KEY=your-openai-key
# RALPH_PROVIDER=deep-agents
# RALPH_MODEL=openai:gpt-4o

# --- Loop Settings ---
# RALPH_MAX_ITERATIONS=50
# RALPH_MAX_BUDGET_USD=10.00
# RALPH_MAX_HEALER_ATTEMPTS=5

# --- Azure Foundry (optional) ---
# CLAUDE_CODE_USE_FOUNDRY=1
# ANTHROPIC_FOUNDRY_API_KEY=your-foundry-key
# ANTHROPIC_FOUNDRY_BASE_URL=https://your-endpoint.azure.com/anthropic/
